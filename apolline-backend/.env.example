# PostgreSQL
DATABASE_URL=postgresql://apolline:CHANGE_ME@127.0.0.1:5432/apolline

# JWT — générer un secret de 64+ caractères :
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_BASE64_STRING

# Durée de vie d'un token JWT (en heures)
JWT_TTL_HOURS=12

# Port HTTP du backend (en local, derrière nginx)
PORT=3000

# Origines autorisées (CORS) — l'app Tauri envoie Origin "tauri://localhost" (Win) ou "https://tauri.localhost"
# Pour le dev navigateur (npm run dev) : http://localhost:5173
# Sépare par des virgules.
ALLOWED_ORIGINS=tauri://localhost,https://tauri.localhost,http://localhost:5173,http://localhost:1420
